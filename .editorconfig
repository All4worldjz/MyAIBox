# EditorConfig - 跨编辑器配置
# https://editorconfig.org

root = true

# 默认设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python文件
[*.py]
indent_size = 4

# YAML文件
[*.{yml,yaml}]
indent_size = 2

# Markdown文件
[*.md]
trim_trailing_whitespace = false

# JSON文件
[*.json]
indent_size = 2

# Shell脚本
[*.sh]
indent_size = 2
mode = shell

# Makefile
[Makefile]
indent_style = tab