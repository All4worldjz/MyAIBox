# KSC AIBox 主机清单示例
# 复制此文件到 ansible/inventory/hosts 并修改

[aibox]
# 目标服务器IP地址
10.212.128.192

[aibox:vars]
# SSH连接配置
ansible_user=root
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_python_interpreter=/usr/bin/python3

# 连接超时设置
ansible_timeout=30
ansible_ssh_common_args='-o StrictHostKeyChecking=no'